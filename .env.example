# Copy this file to .env and fill in your real values
# cp .env.example .env

NODE_ENV=production

# ── CRM Laravel app URL — NO trailing slash ───────────────────────────────────
CRM_URL=https://your-crm-domain.com

# ── Shared secret between this gateway and the CRM ────────────────────────────
# Must match WHATSAPP_GATEWAY_SECRET in your Laravel .env
GATEWAY_SECRET=change-this-to-a-strong-secret

# ── This gateway's own public URL ─────────────────────────────────────────────
GATEWAY_URL=https://your-gateway-domain.com

# ── Port the Node server listens on ───────────────────────────────────────────
PORT=3000

# ── Dashboard login credentials ───────────────────────────────────────────────
GATEWAY_UI_USER=admin@yourdomain.com
GATEWAY_UI_PASSWORD=change-this-password

# ── Session secret — use a long random string ─────────────────────────────────
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_SESSION_SECRET=change-this-to-a-long-random-string

# ── Auth credentials directory (optional — defaults to src/auth_info/) ────────
# AUTH_DIR=/absolute/path/to/auth_info

# ── Log level: error | warn | info | debug ────────────────────────────────────
LOG_LEVEL=info
