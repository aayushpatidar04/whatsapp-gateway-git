# Copy this file to .env and fill in your real values
# cp .env.example .env

NODE_ENV=production

# ── CRM Laravel app URL — NO trailing slash ───────────────────────────────────
# CRM_URL=http://127.0.1:8000
CRM_URL=https://crm.arihantcapital.com

# ── Shared secret between this gateway and the CRM ────────────────────────────
# Must match WHATSAPP_GATEWAY_SECRET in your Laravel .env
GATEWAY_SECRET=aayush-patidar

# ── This gateway's own public URL ─────────────────────────────────────────────
GATEWAY_URL=https://whatsapp.arihantcapital.com
# GATEWAY_URL=http://127.0.1:3000

# ── Port the Node server listens on ───────────────────────────────────────────
PORT=3000

# ── Dashboard login credentials ───────────────────────────────────────────────
GATEWAY_UI_USER=admin@intouchconnect.com
GATEWAY_UI_PASSWORD=Aayush@123

# ── Session secret — use a long random string ─────────────────────────────────
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_SESSION_SECRET=aayush-patidar

# ── Auth credentials directory (optional — defaults to src/auth_info/) ────────
# AUTH_DIR=/absolute/path/to/auth_info

# ── Log level: error | warn | info | debug ────────────────────────────────────
LOG_LEVEL=info

CRM_MAX_MEDIA_BYTES=5242880
CRM_MEDIA_UPLOAD_URL=http://127.0.1:8000/api/gateway/upload-media
# CRM_MEDIA_UPLOAD_URL=https://crm.intouchsoftware.co.in/api/gateway/upload-media
CRM_MEDIA_UPLOAD_TIMEOUT_MS=3000000